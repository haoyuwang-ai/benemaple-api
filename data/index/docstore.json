.canada.ca/content/dam/cra-arc/camp-promo/factsheet/fctsht_nw_cnd-en.pdf", "source_type": "pdf", "jurisdiction": "federal", "language": "en", "retrieved_at": "2026-07-13", "parser_provider": "llamaparse", "parser_tier": "agentic", "parser_version": "latest"}, "hash": "26235f3ad63b7378beed07a6210c6ef6eee1d1309e99b9a2a3a322f36dbe3004", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "589e4289-e122-4319-a7b0-fb27521fae1e", "node_type": "1", "metadata": {"header_path": "/"}, "hash": "c22dbde1121eb1cf785245c8313fd3171364aab97ab68efaa904374914a1bbc8", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "# New to Canada? Make sure you are getting your payments\n\nCollage of icons (gear, screen, dollar sign, people, document) and a photo of a man and a child on bicycles\n\nYou could be eligible for financial support from the Government of Canada. Apply for benefit and credit payments as soon as you arrive and do your taxes every year.\n\nCanada Revenue Agency / Agence du revenu du Canada logo\n\nCanada Revenue Agency\nAgence du revenu du Canada\n\nCanada wordmark with flag\n\n---", "mimetype": "text/plain", "start_char_idx": 0, "end_char_idx": 470, "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "589e4289-e122-4319-a7b0-fb27521fae1e": {"__data__": {"id_": "589e4289-e122-4319-a7b0-fb27521fae1e", "embedding": null, "metadata": {"document_id": "cra-new-to-canada-factsheet-en", "title": "New to Canada? Make sure you are getting your payments", "source_url": "https://www.canada.ca/content/dam/cra-arc/camp-promo/factsheet/fctsht_nw_cnd-en.pdf", "source_type": "pdf", "jurisdiction": "federal", "language": "en", "retrieved_at": "2026-07-13", "parser_provider": "llamaparse", "parser_tier": "agentic", "parser_version": "latest", "header_path": "/"}, "excluded_embed_metadata_keys": ["document_id", "source_url", "source_type", "language", "retrieved_at", "parser_provider", "parser_tier", "parser_version"], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "cra-new-to-canada-factsheet-en", "node_type": "4", "metadata": {"document_id": "cra-new-to-canada-factsheet-en", "title": "New to Canada? Make sure you are getting your payments", "source_url": "https://www.canada.ca/content/dam/cra-arc/camp-promo/factsheet/fctsht_nw_cnd-en.pdf", "source_type": "pdf", "jurisdiction": "federal", "language": "en", "retrieved_at": "2026-07-13", "parser_provider": "llamaparse", "parser_tier": "agentic", "parser_version": "latest"}, "hash": "26235f3ad63b7378beed07a6210c6ef6eee1d1309e99b9a2a3a322f36dbe3004", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "e62c3d5f-ea00-46c0-b715-d3a7714c81cd", "node_type": "1", "metadata": {"document_id": "cra-new-to-canada-factsheet-en", "title": "New to Canada? Make sure you are getting your payments", "source_url": "https://www.canada.ca/content/dam/cra-arc/camp-promo/factsheet/fctsht_nw_cnd-en.pdf", "source_type": "pdf", "jurisdiction": "federal", "language": "en", "retrieved_at": "2026-07-13", "parser_provider": "llamaparse", "parser_tier": "agentic", "parser_version": "latest", "header_path": "/"}, "hash": "b262ed5bad2d91e4d7795a19c42627b93b4bf5125ee9a833052263a37e7c94f9", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "8312ce24-b5d9-4b5f-afa7-ce39e8ab4629", "node_type": "1", "metadata": {"header_path": "/"}, "hash": "27481f82dc9211bc869c9070d27178840b88c58ef97614b1437298aabaf3e8de", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "# Benefit and credit payments you could get\n\n<table>\n  <thead>\n    <tr>\n        <th>Payment</th>\n        <th>How often</th>\n        <th>Helps to...</th>\n        <th>How to get it*</th>\n    </tr>\n  </thead>\n  <tbody>\n    <tr>\n        <td>Goods and services tax/harmonized sales tax (GST/HST) credit</td>\n<td>July, October, January and April</td>\n<td>offset the cost of GST or HST paid on products and services</td>\n<td>Apply using <strong>Form RC151</strong><sup>\\*\\*</sup> <strong>and</strong> do your taxes every year</td>\n    </tr>\n<tr>\n        <td>Canada child benefit (CCB)</td>\n<td>Monthly</td>\n<td>support the needs of children under 18</td>\n<td>Apply using <strong>Form RC66</strong><sup>\\*\\*</sup> <strong>and</strong> do your taxes every year</td>\n    </tr>\n<tr>\n        <td>Child disability benefit</td>\n<td>Monthly</td>\n<td>support the needs of a child under 18 who is living with a disability and is eligible for the disability tax credit (DTC)<sup>\\*\\*\\*</sup></td>\n<td>Do your taxes every year <strong>and</strong> be eligible for the CCB</td>\n    </tr>\n<tr>\n        <td>Provincial and territorial benefit and credit payments</td>\n<td>Varies</td>\n<td>offset certain costs by province and territory (payments calculated based on your tax return)</td>\n<td>Do your taxes every year</td>\n    </tr>\n  </tbody>\n</table>\n\n<sup>\\*</sup> In addition to meeting the eligibility criteria\n\n<sup>\\*\\*</sup> More information on this form below\n\n<sup>\\*\\*\\*</sup> More information on the DTC: canada.ca/disability-tax-credit\n\n---", "mimetype": "text/plain", "start_char_idx": 472, "end_char_idx": 2000, "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "8312ce24-b5d9-4b5f-afa7-ce39e8ab4629": {"__data__": {"id_": "8312ce24-b5d9-4b5f-afa7-ce39e8ab4629", "embedding": null, "metadata": {"document_id": "cra-new-to-canada-factsheet-en", "title": "New to Canada? Make sure you are getting your payments", "source_url": "https://www.canada.ca/content/dam/cra-arc/camp-promo/factsheet/fctsht_nw_cnd-en.pdf", "source_type": "pdf", "jurisdiction": "federal", "language": "en", "retrieved_at": "2026-07-13", "parser_provider": "llamaparse", "parser_tier": "agentic", "parser_version": "latest", "header_path": "/"}, "excluded_embed_metadata_keys": ["document_id", "source_url", "source_type", "language", "retrieved_at", "parser_provider", "parser_tier", "parser_version"], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "cra-new-to-canada-factsheet-en", "node_type": "4", "metadata": {"document_id": "cra-new-to-canada-factsheet-en", "title": "New to Canada? Make sure you are getting your payments", "source_url": "https://www.canada.ca/content/dam/cra-arc/camp-promo/factsheet/fctsht_nw_cnd-en.pdf", "source_type": "pdf", "jurisdiction": "federal", "language": "en", "retrieved_at": "2026-07-13", "parser_provider": "llamaparse", "parser_tier": "agentic", "parser_version": "latest"}, "hash": "26235f3ad63b7378beed07a6210c6ef6eee1d1309e99b9a2a3a322f36dbe3004", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "589e4289-e122-4319-a7b0-fb27521fae1e", "node_type": "1", "metadata": {"document_id": "cra-new-to-canada-factsheet-en", "title": "New to Canada? Make sure you are getting your payments", "source_url": "https://www.canada.ca/content/dam/cra-arc/camp-promo/factsheet/fctsht_nw_cnd-en.pdf", "source_type": "pdf", "jurisdiction": "federal", "language": "en", "retrieved_at": "2026-07-13", "parser_provider": "llamaparse", "parser_tier": "agentic", "parser_version": "latest", "header_path": "/"}, "hash": "5724d90b8cefbe21a01f6bf18d9532e3ef4c212397cc371343489bb69faa2b37", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "413a8180-a36d-4c2e-9251-d1d698e52c09", "node_type": "1", "metadata": {"header_path": "/"}, "hash": "a72ee9644b0c2a1520d0a07380864a89acfdf8af8c60fae54193541b4dc01b78", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "# Find out if you are eligible\n\nFor all benefit and credit payments, you must be a resident of Canada for income tax purposes. A resident for income tax purposes has significant ties in Canada, such as a home, a spouse or common-law partner, or dependants.\n\nFor some benefit and credit payments, you must also have a valid immigration status, such as a:\n\n* Canadian citizen or permanent resident\n\n* protected person, or\n\n* temporary resident who has lived in Canada for the previous 18 months and who has a valid permit in the 19<sup>th</sup> month\n\n    - Inform the Canada Revenue Agency (CRA) if your permit is renewed to avoid interruptions to your benefit and credit payments", "mimetype": "text/plain", "start_char_idx": 2002, "end_char_idx": 2681, "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "413a8180-a36d-4c2e-9251-d1d698e52c09": {"__data__": {"id_": "413a8180-a36d-4c2e-9251-d1d698e52c09", "embedding": null, "metadata": {"document_id": "cra-new-to-canada-factsheet-en", "title": "New to Canada? Make sure you are getting your payments", "source_url": "https://www.canada.ca/content/dam/cra-arc/camp-promo/factsheet/fctsht_nw_cnd-en.pdf", "source_type": "pdf", "jurisdiction": "federal", "language": "en", "retrieved_at": "2026-07-13", "parser_provider": "llamaparse", "parser_tier": "agentic", "parser_version": "latest", "header_path": "/"}, "excluded_embed_metadata_keys": ["document_id", "source_url", "source_type", "language", "retrieved_at", "parser_provider", "parser_tier", "parser_version"], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "cra-new-to-canada-factsheet-en", "node_type": "4", "metadata": {"document_id": "cra-new-to-canada-factsheet-en", "title": "New to Canada? Make sure you are getting your payments", "source_url": "https://www.canada.ca/content/dam/cra-arc/camp-promo/factsheet/fctsht_nw_cnd-en.pdf", "source_type": "pdf", "jurisdiction": "federal", "language": "en", "retrieved_at": "2026-07-13", "parser_provider": "llamaparse", "parser_tier": "agentic", "parser_version": "latest"}, "hash": "26235f3ad63b7378beed07a6210c6ef6eee1d1309e99b9a2a3a322f36dbe3004", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "8312ce24-b5d9-4b5f-afa7-ce39e8ab4629", "node_type": "1", "metadata": {"document_id": "cra-new-to-canada-factsheet-en", "title": "New to Canada? Make sure you are getting your payments", "source_url": "https://www.canada.ca/content/dam/cra-arc/camp-promo/factsheet/fctsht_nw_cnd-en.pdf", "source_type": "pdf", "jurisdiction": "federal", "language": "en", "retrieved_at": "2026-07-13", "parser_provider": "llamaparse", "parser_tier": "agentic", "parser_version": "latest", "header_path": "/"}, "hash": "5330457125f90774ded4f03d8feb97ab3964f2cad3584ac8e2f4093e2de074c1", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "941eb0a8-e0ac-4f61-b000-01ef3676558f", "node_type": "1", "metadata": {"header_path": "/"}, "hash": "7faea919f0c7db97a3804241302e410ee46be43b65bffab6d3c99a22c316e087", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "# How to get benefit and credit payments\n\nApply for payments as soon as you arrive in Canada, even if you do not have a social insurance number (SIN). For **CRA forms, always use your first and last name in the same order.** If you have one name, use it as a last name.\n\nFor the **CCB** and **GST/HST credit** payments, complete one of these forms:\n\n* If you have children and you or your spouse or common-law partner meet the CCB eligibility criteria, complete **Form RC66, Canada Child Benefits Application** and include **Form RC66SCH, Status in Canada and Income Information for the Canada Child Benefits Application.**\n\n* If you do not have children, or you do, but do not meet the CCB eligibility criteria, complete **Form RC151, GST/HST Credit and Canada Carbon Rebate Application for Individuals Who Become Residents of Canada.**", "mimetype": "text/plain", "start_char_idx": 2683, "end_char_idx": 3520, "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "941eb0a8-e0ac-4f61-b000-01ef3676558f": {"__data__": {"id_": "941eb0a8-e0ac-4f61-b000-01ef3676558f", "embedding": null, "metadata": {"document_id": "cra-new-to-canada-factsheet-en", "title": "New to Canada? Make sure you are getting your payments", "source_url": "https://www.canada.ca/content/dam/cra-arc/camp-promo/factsheet/fctsht_nw_cnd-en.pdf", "source_type": "pdf", "jurisdiction": "federal", "language": "en", "retrieved_at": "2026-07-13", "parser_provider": "llamaparse", "parser_tier": "agentic", "parser_version": "latest", "header_path": "/"}, "excluded_embed_metadata_keys": ["document_id", "source_url", "source_type", "language", "retrieved_at", "parser_provider", "parser_tier", "parser_version"], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "cra-new-to-canada-factsheet-en", "node_type": "4", "metadata": {"document_id": "cra-new-to-canada-factsheet-en", "title": "New to Canada? Make sure you are getting your payments", "source_url": "https://www.canada.ca/content/dam/cra-arc/camp-promo/factsheet/fctsht_nw_cnd-en.pdf", "source_type": "pdf", "jurisdiction": "federal", "language": "en", "retrieved_at": "2026-07-13", "parser_provider": "llamaparse", "parser_tier": "agentic", "parser_version": "latest"}, "hash": "26235f3ad63b7378beed07a6210c6ef6eee1d1309e99b9a2a3a322f36dbe3004", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "413a8180-a36d-4c2e-9251-d1d698e52c09", "node_type": "1", "metadata": {"document_id": "cra-new-to-canada-factsheet-en", "title": "New to Canada? Make sure you are getting your payments", "source_url": "https://www.canada.ca/content/dam/cra-arc/camp-promo/factsheet/fctsht_nw_cnd-en.pdf", "source_type": "pdf", "jurisdiction": "federal", "language": "en", "retrieved_at": "2026-07-13", "parser_provider": "llamaparse", "parser_tier": "agentic", "parser_version": "latest", "header_path": "/"}, "hash": "fd3f20bcc4634e835277293f8e9c70c07837049e5a6f14c2a873b2d88e0801db", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "43e8682c-48e6-43f1-84f3-a00ec7b0ceb4", "node_type": "1", "metadata": {"header_path": "/What you need to do your taxes/"}, "hash": "4d58f1f864f43295cb1588dda86a4744ea1aa4555dc6c5d794237f35a31384e2", "class_name": "RelatedNodeInfo"}}, "metada