: "federal", "language": "en", "retrieved_at": "2026-07-13", "parser_provider": "llamaparse", "parser_tier": "agentic", "parser_version": "latest", "header_path": "/"}, "hash": "48a732d951c1762d21c258f2ea82bc603fcb7231ce5235987f714d5290c7f206", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "f042edc5-83e0-4151-9561-436837469d0c", "node_type": "1", "metadata": {"header_path": "/"}, "hash": "9ad2df4c0926936a5eee14c21a0614e7afcc9a67025af9642a12ba66d8e3f763", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "## Social insurance number (SIN)\n\nTo work in Canada or access certain government programs and benefits, you need a SIN. If you do not have a SIN or have lost it, contact Service Canada at 1-866-274-6627 or go to an office near you.", "mimetype": "text/plain", "start_char_idx": 3556, "end_char_idx": 3787, "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "f042edc5-83e0-4151-9561-436837469d0c": {"__data__": {"id_": "f042edc5-83e0-4151-9561-436837469d0c", "embedding": null, "metadata": {"document_id": "cra-new-to-canada-factsheet-en", "title": "New to Canada? Make sure you are getting your payments", "source_url": "https://www.canada.ca/content/dam/cra-arc/camp-promo/factsheet/fctsht_nw_cnd-en.pdf", "source_type": "pdf", "jurisdiction": "federal", "language": "en", "retrieved_at": "2026-07-13", "parser_provider": "llamaparse", "parser_tier": "agentic", "parser_version": "latest", "header_path": "/"}, "excluded_embed_metadata_keys": ["document_id", "source_url", "source_type", "language", "retrieved_at", "parser_provider", "parser_tier", "parser_version"], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "cra-new-to-canada-factsheet-en", "node_type": "4", "metadata": {"document_id": "cra-new-to-canada-factsheet-en", "title": "New to Canada? Make sure you are getting your payments", "source_url": "https://www.canada.ca/content/dam/cra-arc/camp-promo/factsheet/fctsht_nw_cnd-en.pdf", "source_type": "pdf", "jurisdiction": "federal", "language": "en", "retrieved_at": "2026-07-13", "parser_provider": "llamaparse", "parser_tier": "agentic", "parser_version": "latest"}, "hash": "26235f3ad63b7378beed07a6210c6ef6eee1d1309e99b9a2a3a322f36dbe3004", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "43e8682c-48e6-43f1-84f3-a00ec7b0ceb4", "node_type": "1", "metadata": {"document_id": "cra-new-to-canada-factsheet-en", "title": "New to Canada? Make sure you are getting your payments", "source_url": "https://www.canada.ca/content/dam/cra-arc/camp-promo/factsheet/fctsht_nw_cnd-en.pdf", "source_type": "pdf", "jurisdiction": "federal", "language": "en", "retrieved_at": "2026-07-13", "parser_provider": "llamaparse", "parser_tier": "agentic", "parser_version": "latest", "header_path": "/What you need to do your taxes/"}, "hash": "829fe8239e6ae25c457df23fe2130c63051f36edfd0c9f2b9430d7e6de5b81cc", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "981fd44a-bb37-4048-abe5-2aa4992a0820", "node_type": "1", "metadata": {"header_path": "/"}, "hash": "9eb88aa81f1cf68f95ea41a1bf47d02d6a4e1d3874c7a0e53b516a66c2656ed4", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "# Tax slips\n\nAt the beginning of the calendar year, you should receive tax slips with the information you need to do your taxes. If they are missing, get them online in My Account or call the CRA at 1-800-959-8281.\n\n**Do your taxes by April 30 each year to keep getting your payments:** If you are married or in a common-law relationship, both you and your partner need to file. In Quebec, you also need to file a separate provincial tax return with Revenu Qu\u00e9bec. Find more information at canada.ca/taxes-get-ready", "mimetype": "text/plain", "start_char_idx": 3789, "end_char_idx": 4304, "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "981fd44a-bb37-4048-abe5-2